<!-- pages/pair/pair.wxml - WiFi 配对页面 -->
<view class="container">

  <!-- 已配对状态 -->
  <view wx:if="{{paired}}" class="paired-state">
    <view class="paired-icon-wrapper">
      <view class="paired-icon-circle">
        <text class="paired-check">✓</text>
      </view>
    </view>
    <text class="paired-title">WiFi 已连接</text>
    <text class="paired-desc">已连接到 {{serverUrl || '服务器'}}</text>

    <view class="pair-info card">
      <view class="pair-info-row">
        <text class="pair-info-label">连接方式</text>
        <text class="pair-info-value">WiFi / WebSocket</text>
      </view>
      <view class="pair-info-row">
        <text class="pair-info-label">服务器</text>
        <text class="pair-info-value">{{serverUrl || '-'}}</text>
      </view>
      <view class="pair-info-row">
        <text class="pair-info-label">连接状态</text>
        <view class="pair-info-value">
          <view class="status-dot {{connected ? 'online' : 'offline'}}"></view>
          <text>{{connected ? '已连接' : '断开中'}}</text>
        </view>
      </view>
    </view>

    <button class="btn-danger" style="margin-top: 48rpx;" bindtap="unpair">断开连接</button>
  </view>

  <!-- 未配对 - 配对表单 -->
  <view wx:else>
    <!-- 步骤引导 -->
    <view class="pair-guide">
      <view class="step-card card">
        <view class="step-number">1</view>
        <view class="step-content">
          <text class="step-title">在电脑浏览器打开 ScanBridge</text>
          <text class="step-desc">打开网页后会显示配对码和 WiFi 地址</text>
        </view>
      </view>

      <view class="step-card card">
        <view class="step-number">2</view>
        <view class="step-content">
          <text class="step-title">输入配对信息</text>
          <text class="step-desc">填写地址和配对码即可完成配对</text>
        </view>
      </view>
    </view>

    <!-- 服务器地址输入 -->
    <view class="card ws-input-section">
      <text class="ws-input-label">服务器地址</text>
      <view class="ws-input-row">
        <input
          class="ws-input"
          type="text"
          placeholder="例如：ws://192.168.5.27:8080"
          value="{{inputServerUrl}}"
          bindinput="onServerUrlInput"
          confirm-type="done"
          bindconfirm="startWSPair"
        />
        <button class="btn-paste" bindtap="pasteServerUrl">粘贴</button>
      </view>
      <text class="ws-input-hint">手机和电脑必须在同一个 WiFi 下</text>
    </view>

    <!-- 配对码输入 -->
    <view class="card ws-input-section">
      <text class="ws-input-label">配对码（网页上显示的 6 位码）</text>
      <view class="pair-code-row">
        <input
          class="pair-code-input"
          type="text"
          maxlength="6"
          placeholder="000000"
          value="{{inputPairCode}}"
          bindinput="onPairCodeInput"
          confirm-type="done"
          bindconfirm="startWSPair"
        />
      </view>
    </view>

    <!-- 连接按钮 -->
    <button
      class="btn-primary ws-connect-btn"
      bindtap="startWSPair"
      loading="{{wsConnecting}}"
      disabled="{{wsConnecting || !inputServerUrl || !inputPairCode}}"
    >
      {{wsConnecting ? '正在连接...' : '🔗 开始配对'}}
    </button>

    <!-- 连接状态提示 -->
    <view wx:if="{{wsStatusMsg}}" class="ws-status {{wsStatusError ? 'error' : ''}}">
      <text>{{wsStatusMsg}}</text>
    </view>

    <!-- 快捷填入 -->
    <view wx:if="{{!wsConnecting && !paired}}" class="ws-quick-fill card">
      <text class="quick-fill-title">快捷操作</text>
      <view class="quick-fill-btn" bindtap="fillFromSaved">
        <text>使用上次保存的地址</text>
      </view>
    </view>
  </view>
</view>
