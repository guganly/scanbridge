/* pages/pair/pair.wxss - WiFi 配对页面样式 */
.container {
  padding: 32rpx;
}

/* ==================== 已配对状态 ==================== */
.paired-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.paired-icon-wrapper {
  margin-bottom: 32rpx;
}

.paired-icon-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
}

.paired-check {
  font-size: 72rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.paired-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.paired-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.pair-info {
  width: 100%;
}

.pair-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.pair-info-label {
  font-size: 28rpx;
  color: #666;
}

.pair-info-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot.online {
  background: #07C160;
}

.status-dot.offline {
  background: #C0C0C0;
}

/* ==================== 步骤引导 ==================== */
.pair-guide {
  margin-bottom: 16rpx;
}

.step-card {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 32rpx;
  margin-bottom: 12rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #07C160;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.step-content {
  flex: 1;
}

.step-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.step-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

/* ==================== WebSocket 输入区 ==================== */
.ws-input-section {
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.ws-input-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.ws-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ws-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  background: #FAFAFA;
}

.btn-paste {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  font-size: 26rpx;
  background: #F0F0F0;
  color: #666;
  border: none;
  border-radius: 12rpx;
  white-space: nowrap;
}

.ws-input-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.pair-code-row {
  display: flex;
  justify-content: center;
  padding: 8rpx 0;
}

.pair-code-input {
  width: 400rpx;
  height: 96rpx;
  text-align: center;
  font-size: 52rpx;
  font-weight: 600;
  letter-spacing: 16rpx;
  color: #07C160;
  border: 2rpx solid #E5E5E5;
  border-radius: 16rpx;
  background: #FAFAFA;
}

.ws-connect-btn {
  margin-top: 32rpx;
  font-size: 32rpx;
}

/* WS 状态提示 */
.ws-status {
  margin-top: 24rpx;
  padding: 20rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #07C160;
  background: #F0FAF4;
  border-radius: 12rpx;
}

.ws-status.error {
  color: #FA5151;
  background: #FFF1F0;
}

/* 快捷填入 */
.ws-quick-fill {
  margin-top: 24rpx;
  padding: 20rpx 32rpx;
}

.quick-fill-title {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.quick-fill-btn {
  padding: 16rpx 24rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
}

.quick-fill-btn text {
  font-size: 28rpx;
  color: #07C160;
}

/* ==================== 通用按钮 ==================== */
.btn-secondary {
  background: #F8F8F8;
  color: #666;
  border: none;
}

/* ==================== 设置页额外样式 ==================== */
.card-inner {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
}

.ws-quick-tip .tip-title {
  display: block;
  font-size: 27rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.tip-step {
  display: block;
  font-size: 25rpx;
  color: #666;
  line-height: 1.8;
}

.form-value-success {
  color: #07C160 !important;
  font-weight: 500;
}
