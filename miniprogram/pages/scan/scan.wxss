/* pages/scan/scan.wxss */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.status-left {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot.online {
  background: #07C160;
  box-shadow: 0 0 8rpx rgba(7, 193, 96, 0.4);
}

.status-dot.offline {
  background: #C0C0C0;
}

.status-text {
  font-size: 28rpx;
  color: #333;
}

.link-text {
  font-size: 28rpx;
  color: #07C160;
}

.status-paired {
  font-size: 28rpx;
  color: #07C160;
  font-weight: 500;
}

/* 扫码区域 */
.scan-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.scan-button {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
  transition: all 0.2s ease;
}

.scan-button:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.scan-button.sending {
  background: #4A90D9;
}

.scan-button.success {
  background: #07C160;
}

.scan-button.failed {
  background: #FA5151;
}

.scan-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-icon-frame {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #FFFFFF;
  border-radius: 12rpx;
  position: relative;
  margin-bottom: 16rpx;
}

.scan-icon-frame::before,
.scan-icon-frame::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border: 6rpx solid #FFFFFF;
}

.scan-icon-frame::before {
  top: -6rpx;
  left: -6rpx;
  border-right: none;
  border-bottom: none;
  border-radius: 8rpx 0 0 0;
}

.scan-icon-frame::after {
  bottom: -6rpx;
  right: -6rpx;
  border-left: none;
  border-top: none;
  border-radius: 0 0 8rpx 0;
}

.scan-icon-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.scan-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #FFFFFF;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.scan-success,
.scan-failed {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #FFFFFF;
}

.check-mark {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.cross-mark {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.scan-hint {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #999;
}

.scan-count {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #CCC;
}

/* 结果卡片 */
.result-card {
  margin-top: 20rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.result-time {
  font-size: 24rpx;
  color: #999;
}

.result-duplicate {
  font-size: 22rpx;
  color: #fff;
  background: #FAAD14;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.result-content {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.result-text {
  font-size: 32rpx;
  color: #1A1A1A;
  word-break: break-all;
  line-height: 1.6;
}

.result-format {
  margin-bottom: 24rpx;
}

.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.format-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #666;
  background: #F0F0F0;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.sn-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #07C160;
  background: #E0F5E0;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

/* v2.0 标签 & 设备型号 */
.tag-section {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.device-model-row {
  margin-bottom: 16rpx;
}

.model-input {
  width: 100%;
  height: 64rpx;
  font-size: 26rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.tags-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-label {
  font-size: 24rpx;
  color: #999;
}

.tag-item {
  font-size: 22rpx;
  color: #1E6FFF;
  background: #E8F0FE;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.tag-add-btn {
  font-size: 24rpx;
  color: #07C160;
  padding: 4rpx 12rpx;
}

.tag-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.tag-input {
  flex: 1;
  height: 64rpx;
  font-size: 26rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.tag-confirm-btn {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #fff;
  background: #07C160;
  border-radius: 8rpx;
  padding: 0 20rpx;
  border: none;
}

.tag-cancel-btn {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #999;
  background: #F0F0F0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  border: none;
}

.result-actions {
  display: flex;
  align-items: center;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #CCC;
}

.empty-hint {
  font-size: 24rpx;
  color: #DDD;
  margin-top: 8rpx;
}
