/* pages/history/history.wxss */
.container {
  padding: 24rpx;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 28rpx 20rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #F0F0F0;
}

/* 记录列表 */
.history-list {
  margin-bottom: 24rpx;
}

.history-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.item-badges {
  display: flex;
  gap: 8rpx;
  flex: 1;
  margin: 0 12rpx;
}

.item-badge {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

.item-badge.sn-badge {
  color: #07C160;
  background: #E0F5E0;
}

.item-badge.dup-badge {
  color: #FAAD14;
  background: #FFF7E0;
}

.item-format {
  font-size: 22rpx;
  color: #666;
  background: #F0F0F0;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.item-status {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-dot.online {
  background: #07C160;
}

.status-dot.error {
  background: #FA5151;
}

.status-dot.pending {
  background: #FFC300;
}

.status-label {
  font-size: 24rpx;
  color: #999;
}

.item-content {
  background: #F8F8F8;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.item-text {
  font-size: 30rpx;
  color: #1A1A1A;
  word-break: break-all;
  line-height: 1.6;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.item-device-model {
  font-size: 22rpx;
  color: #1E6FFF;
  background: #E8F0FE;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.item-add-model {
  font-size: 22rpx;
  color: #BBB;
  padding: 2rpx 12rpx;
}

.item-time {
  font-size: 22rpx;
  color: #BBB;
}

/* 操作面板 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}

.action-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-item {
  text-align: center;
  padding: 32rpx;
  font-size: 32rpx;
  color: #333;
  border-bottom: 1rpx solid #F0F0F0;
}

.action-item.danger {
  color: #FA5151;
}

.action-cancel {
  text-align: center;
  padding: 32rpx;
  font-size: 32rpx;
  color: #999;
  margin-top: 12rpx;
  border-top: 12rpx solid #F5F5F5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #CCC;
}

.empty-hint {
  font-size: 24rpx;
  color: #DDD;
  margin-top: 8rpx;
}

/* v2.0 筛选栏 */
.filter-bar {
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-chip {
  font-size: 24rpx;
  color: #666;
  background: #F0F0F0;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.filter-chip.active {
  color: #fff;
  background: #07C160;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0F0F0;
}

.export-csv-btn {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #fff;
  background: #07C160;
  border-radius: 28rpx;
  padding: 0 28rpx;
  border: none;
}

.export-csv-btn::after {
  border: none;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0F0F0;
}

.tag-option {
  font-size: 22rpx;
  color: #666;
  background: #F0F0F0;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.tag-option.active {
  color: #fff;
  background: #1E6FFF;
}

/* 记录标签 */
.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.item-tag {
  font-size: 20rpx;
  color: #1E6FFF;
  background: #E8F0FE;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

/* 编辑设备型号弹窗 */
.edit-model-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.edit-model-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.edit-model-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.edit-model-actions {
  display: flex;
  gap: 16rpx;
}

.edit-model-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  text-align: center;
}

.edit-model-btn.cancel {
  background: #F0F0F0;
  color: #666;
}

.edit-model-btn.confirm {
  background: #07C160;
  color: #fff;
}
