/* pages/settings/settings.wxss */
.container {
  padding: 24rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #333;
}

.form-value {
  font-size: 28rpx;
  color: #07C160;
}

.form-value-danger {
  font-size: 28rpx;
  color: #FA5151;
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.picker-arrow {
  font-size: 28rpx;
  color: #CCC;
  margin-left: 12rpx;
}

/* 模式选择 */
.mode-options {
  display: flex;
  gap: 16rpx;
}

.mode-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  border-radius: 12rpx;
  background: #F8F8F8;
  transition: all 0.3s;
}

.mode-option.active {
  background: #E8F5E9;
  border: 2rpx solid #07C160;
}

.mode-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.mode-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.mode-option.active .mode-name {
  color: #07C160;
}

.mode-desc {
  font-size: 24rpx;
  color: #999;
}

.footer {
  text-align: center;
  padding: 48rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #DDD;
}

.form-value-success {
  font-size: 28rpx;
  color: #07C160;
  font-weight: 500;
}

/* WS 快速提示 */
.card-inner {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
}

.ws-quick-tip .tip-title {
  display: block;
  font-size: 27rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.tip-step {
  display: block;
  font-size: 25rpx;
  color: #666;
  line-height: 1.8;
}

.btn-primary {
  background: #07C160;
  color: #FFFFFF;
  border-radius: 12rpx;
}

.btn-danger {
  background: #FA5151;
  color: #FFFFFF;
  border-radius: 12rpx;
}

/* 下载引导 */
.download-guide {
  margin-bottom: 16rpx;
}

.download-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.download-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.download-options {
  margin-top: 8rpx;
}

.download-option-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.download-option-desc {
  display: block;
  font-size: 25rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.btn-download {
  margin-top: 12rpx;
  padding: 12rpx 0;
  width: 100%;
  font-size: 28rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 8rpx;
  border: none;
}

/* 步骤列表 & 前提列表 */
.step-list .tip-title {
  display: block;
  font-size: 27rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.step-item, .require-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.step-item:last-child, .require-item:last-child {
  margin-bottom: 0;
}

.step-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  font-size: 22rpx;
  color: #fff;
  background: #07C160;
  border-radius: 50%;
  margin-right: 14rpx;
  margin-top: 4rpx;
}

.step-text, .require-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 提示列表 */
.tip-list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.tip-list-item:last-child {
  margin-bottom: 0;
}

.tip-bullet {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
  margin-top: 2rpx;
  line-height: 1.6;
}

.tip-text {
  flex: 1;
  font-size: 25rpx;
  color: #666;
  line-height: 1.7;
}

.require-check {
  font-size: 28rpx;
  margin-right: 12rpx;
  margin-top: 2rpx;
}
